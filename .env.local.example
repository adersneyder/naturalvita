# ===================================
# NaturalVita - Variables de entorno
# ===================================
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA subas .env.local a GitHub.

# --- Supabase (base de datos, auth, storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# --- Bold (pasarela de pagos Colombia) ---
BOLD_IDENTITY_KEY=tu-identity-key
BOLD_SECRET_KEY=tu-secret-key

# --- Anthropic (chatbot con Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Klaviyo (email marketing) ---
KLAVIYO_PRIVATE_API_KEY=pk_...
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=...

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=https://naturalvita.co
